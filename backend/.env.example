SPRING_PROFILES_ACTIVE=dev
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# Usuario dedicado — deve bater com MYSQL_USER e MYSQL_PASSWORD do db/.env
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/pontocerto?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75 -Djava.security.egd=file:/dev/./urandom -Dspring.backgroundpreinitializer.ignore=true
